# =====================================================================
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
# NEVER commit your real .env (it is git-ignored). No secret is ever read
# from config.yaml or hardcoded in source -- only from here / the environment.
# =====================================================================

# --- NCBI / PubMed E-utilities --------------------------------------
# Optional but STRONGLY recommended: raises your rate limit from 3 to 10
# requests/sec. Get one (free) at https://www.ncbi.nlm.nih.gov/account/
# -> Settings -> API Key Management.
NCBI_API_KEY=

# NCBI asks that automated tools identify a contact email. Used in the
# request only; not required.
NCBI_EMAIL=you@example.edu

# --- Logging --------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Optional email delivery (SMTP) ---------------------------------
# Only needed if you run with --email or set email.enabled: true in config.
# Example for Gmail uses an APP PASSWORD (not your account password):
#   https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@gmail.com
SMTP_TO=you@example.edu,colleague@example.edu
# Set to "true" to use implicit SSL (port 465) instead of STARTTLS (587).
SMTP_USE_SSL=false
